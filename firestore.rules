rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: is the caller signed in with a real account (not anonymous)?
    // Arena uses anonymous sign-in for guest mode, which can play
    // ephemeral rooms but MUST NOT touch persistent collections
    // (leaderboard, H2H, daily, users/{uid}).
    function isRegistered() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Users can only read/write their own data. Anonymous users have no
    // persistent profile, so we explicitly block them here even though
    // their uid would otherwise match — they'd just be writing garbage
    // that nobody can ever read back after the anon session expires.
    match /users/{userId} {
      allow read, write: if isRegistered() && request.auth.uid == userId;

      // Recursive rule for all subcollections and documents
      match /{document=**} {
        allow read, write: if isRegistered() && request.auth.uid == userId;
      }
    }

    // Alternative: More granular control per namespace. NOTE — this rule
    // is shadowed by the recursive /users/{userId}/{document=**} match
    // above; Firestore unions allow rules so the permissive parent
    // disables the validation here. Kept in sync with the deployed
    // ruleset so a CLI deploy from this file doesn't drift.
    match /users/{userId}/apps/{namespace} {
      allow read: if isRegistered() && request.auth.uid == userId;

      allow write: if isRegistered()
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['data', 'meta'])
        && request.resource.data.meta.keys().hasAll(['lastUpdated']);
    }

    // ---------- Trivia Arena ----------
    // Multiplayer game rooms. Any signed-in user can read any room (so
    // they can join with a code) and write to the room doc (host advances
    // questions; players touch lastSeen-style fields). App-level password
    // check gates private rooms — rules deliberately stay loose because
    // game state is client-of-truth. Tighten with field-level conditions
    // if abuse shows up.
    match /triviaRooms/{roomCode} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }
    // Each player owns their own player doc. Score increments and answer
    // writes happen here under the player's own uid — the host can't
    // silently rewrite someone else's score.
    match /triviaRooms/{roomCode}/players/{playerUid} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null
        && request.auth.uid == playerUid;
    }

    // Per-room chat. Any signed-in user can read; each user can only
    // write messages keyed by their own uid in the payload. We cap the
    // text at 280 characters so a runaway client can't spam the doc
    // with megabytes; the rules-side check is the last line of defense
    // (the client also enforces this).
    match /triviaRooms/{roomCode}/chat/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 280;
      // No edits, no recalls — keep chat append-only so moderation is
      // tractable. Hosts who want to "delete" a message can pause the
      // room or end the game instead.
      allow update, delete: if false;
    }

    // Denormalized global XP leaderboard. Read for everyone signed in
    // (guests included — they can browse the boards). Writes require a
    // real account so guest uids can't pollute the public leaderboard.
    // Admins (presence of a doc at /leaderboardAdmins/{uid}) can delete
    // any row — used to moderate stale or abusive entries.
    match /triviaLeaderboard/{userId} {
      allow read: if request.auth != null;
      allow create, update: if isRegistered() && request.auth.uid == userId;
      allow delete: if isRegistered()
        && exists(/databases/$(database)/documents/leaderboardAdmins/$(request.auth.uid));
    }

    // Admin registry for leaderboard moderation. Each doc id is a uid;
    // presence (not the doc contents) grants admin power above. Bootstrap:
    // create the FIRST doc manually in the Firebase Console (anyone with
    // project-owner access can do it); from then on you can manage the
    // list there.
    match /leaderboardAdmins/{userId} {
      allow read: if request.auth != null;
      // Writes are deliberately closed — admin registry is managed via
      // the Firebase Console only, not in-app.
      allow write: if false;
    }

    // Brain Arena — Pairwise head-to-head records.
    // One doc per ordered uid pair (key = "{uidA}__{uidB}" with uidA <
    // uidB lexicographically). Holds Wins/Losses/Ties between those two
    // players across all multiplayer games. Read is open to any signed-
    // in user so the H2H view + lobby badges can fetch arbitrary pairs;
    // write requires the caller to actually be one of the two players
    // in the pair AND to be a registered (non-anonymous) user — guests
    // play ephemerally and shouldn't create H2H pair rows.
    match /triviaH2H/{pairKey} {
      allow read: if request.auth != null;
      allow create, update: if isRegistered()
        && (request.resource.data.uidA == request.auth.uid
            || request.resource.data.uidB == request.auth.uid);
    }

    // Brain Arena — Globe Drop daily challenge leaderboard.
    // Each YYYY-MM-DD doc has a /scores subcollection keyed by uid.
    // Anyone signed in can read (to render the daily top 10); each
    // user can only create/update their own score entry, and must be
    // a registered (non-anonymous) user so guest uids can't claim a
    // daily top spot that would orphan as soon as their session ends.
    match /globeDropDailyLeaderboard/{date}/scores/{userId} {
      allow read: if request.auth != null;
      allow create, update: if isRegistered() && request.auth.uid == userId;
    }

    // Brain Arena — daily Trivia challenge canonical question set.
    // First player of the day seeds it; everyone else reads the same
    // doc so the day's 10 questions are deterministic across players.
    // Writes are open to any signed-in user (including guests) so a
    // guest-only day still seeds; the leaderboard rule below blocks
    // their score from polluting the board.
    match /triviaDaily/{date} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
    }
    // Daily Trivia leaderboard — same shape as the Globe Drop one.
    match /triviaDailyLeaderboard/{date}/scores/{userId} {
      allow read: if request.auth != null;
      allow create, update: if isRegistered() && request.auth.uid == userId;
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
