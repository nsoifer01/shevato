rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Each user owns their own subtree. Used by gym-tracker for progress
    // photos at users/{uid}/gym-tracker/measurements/{measurementId}/{n}.jpg
    // and reserved for any future per-user blob storage.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Deny everything else.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
