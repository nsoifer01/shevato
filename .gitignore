# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore temp files
.*.sw*

# Environment variables
.env
.env.local
.env.production

# Netlify
.netlify/
netlify/functions/node_modules/
netlify/functions/package-lock.json
netlify/pending-functions/node_modules/
netlify/pending-functions/package-lock.json

# Firebase local config (if you want a different local config)
assets/js/firebase-config-local.js

# WhatsApp chat exports (personal data, used locally for MapTap Rivals import)
WhatsApp Chat *.txt
WhatsApp Chat *.txt:Zone.Identifier

# Windows / WSL download metadata
*:Zone.Identifier

# Rising Shows static SEO pages — derived from data.json at build
# time (Netlify or the GitHub Actions refresh workflow). Not committed
# to keep git history clean.
apps/rising-shows/shows/
apps/rising-shows/sitemap-shows.xml

# Rising Shows datasets — published to the rolling "rising-shows-data"
# GitHub release by the refresh workflow and downloaded at build time
# (scripts/fetch-data.js). Never committed: the pair is ~150 MB per
# refresh and was bloating git history.
apps/rising-shows/data.json
apps/rising-shows/data/show-modal-extras.json

# Gym Tracker static SEO pages — derived from exercises-db.json at
# build time. Same rationale as Rising Shows.
apps/gym-tracker/exercises/
apps/gym-tracker/sitemap-exercises.xml

# Local-only change-notes / site-comparison docs. Kept on disk for
# reference, not published to the repo.
.features/

# Transient test-run screenshot evidence (written by the test pipeline,
# reviewed by the owner, deleted at round close). Never committed.
.screenshots/

# Owner-uploaded reference screenshots (Lightshot drops for design review).
# Local-only working material, never published to the repo.
.lightshot-screenshots/

# Netlify Edge Functions lockfile, generated by `netlify dev`
deno.lock
