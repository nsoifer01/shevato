{
  "name": "shevato",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Shevato – personal web apps and tools",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format:check": "prettier --check .",
    "generate-icons": "node scripts/generate-icons.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@netlify/vite-plugin": "^2.10.2",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "vite": "^7.3.1",
    "vite-plugin-compression2": "^2.4.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.js": [
      "eslint",
      "prettier --check"
    ],
    "*.{html,css,json,md}": [
      "prettier --check"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
